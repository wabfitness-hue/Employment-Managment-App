# Employee Management System — environment template
# Copy this file to .env and fill in every value.
# NEVER commit .env to version control — it contains secrets.
#
# Generate strong secrets with:
#   python -c "import secrets; print(secrets.token_hex(64))"

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=Employee Management System
DEBUG=false

# REQUIRED — must be 32+ chars and NOT the default below
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_HEX

# ── Database ──────────────────────────────────────────────────────────────────
# Docker Compose sets DATABASE_URL automatically using POSTGRES_PASSWORD.
# Only set this manually if connecting to an external PostgreSQL server.
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD
# DATABASE_URL=postgresql://ems_user:POSTGRES_PASSWORD@db:5432/ems_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
# REQUIRED — must be 32+ chars, different from SECRET_KEY
JWT_SECRET_KEY=REPLACE_WITH_ANOTHER_64_CHAR_RANDOM_HEX
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Security ──────────────────────────────────────────────────────────────────
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15
SESSION_IDLE_TIMEOUT_MINUTES=60

# Trusted reverse proxy IPs/CIDRs (Docker Nginx bridge network)
# Comma-separated. The backend only accepts X-Forwarded-For from these networks.
# CIDR is supported — the Docker bridge is usually in 172.16.0.0/12.
TRUSTED_PROXY_IPS=127.0.0.1,172.16.0.0/12

# CORS — comma-separated; set to your actual domain in production (no localhost)
CORS_ORIGINS=http://localhost,http://localhost:3000

# ── Microsoft Graph (Outlook) ─────────────────────────────────────────────────
# Leave blank if Outlook photo intake is not needed
MS_CLIENT_ID=
MS_CLIENT_SECRET=

# ── Card Bridge Agent ─────────────────────────────────────────────────────────
# Must match BRIDGE_AGENT_SECRET in bridge_agent/bridge_agent.env
BRIDGE_AGENT_SECRET=REPLACE_WITH_RANDOM_SECRET

# ── Email Alerts (optional SMTP) ──────────────────────────────────────────────
ALERT_EMAIL_FROM=noreply@yourcompany.com
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
