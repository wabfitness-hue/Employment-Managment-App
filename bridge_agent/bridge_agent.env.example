# Bridge Agent configuration
# Copy this file to bridge_agent.env and edit as needed.

# Shared secret — must match BRIDGE_AGENT_SECRET in the backend .env
BRIDGE_AGENT_SECRET=change-me-to-a-random-secret

# WebSocket server (default: localhost only — do not expose to network)
BRIDGE_WS_HOST=127.0.0.1
BRIDGE_WS_PORT=8765

# NFC reader polling interval in milliseconds
NFC_POLL_INTERVAL_MS=250

# Printer settings
# Leave PRINTER_NAME blank to use the Windows/macOS default printer
PRINTER_NAME=
# PRINTER_TYPE: auto | zebra | os | mock
PRINTER_TYPE=auto

# Zebra network printer (only needed if PRINTER_TYPE=zebra)
# ZEBRA_HOST=192.168.1.100
# ZEBRA_PORT=9100

# Log level: DEBUG | INFO | WARNING | ERROR
BRIDGE_LOG_LEVEL=INFO
